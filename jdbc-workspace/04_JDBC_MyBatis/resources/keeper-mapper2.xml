<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
	<mapper namespace ="keeperMapper">
	
		<select id="selectKeeperList"
					resultType="keeper">
		SELECT
					KEEPER_ID
				 ,  KEEPER_NAME
			FROM
					KEEPER
		
		
		
		</select>

		<select id="selectAnimalList"
					resultType="animal"
					parameterType="string">
			SELECT
					ANIMAL_ID
				  , ANIMAL_NAME
			FROM
					ANIMAL
			WHERE
					KEEPER_ID = #{keeperId}		
		
		
		</select>
		
		<resultMap type="keeper" id="keeperWithAnimals">
		<id column="KEEPER_ID" property="keeperId" />
		<result column="KEEPER_NAME" property="keeperName" />
		<collection property="animals" ofType="animal">
			<id column="ANIMAL_ID" property="animalId"/>
			<result column="ANIMAL_NAME" property="animalName" />
		
		</collection>
		
		</resultMap>
		
		<select id="findKeeperAndAnimals" resultMap="keeperWithAnimals">
		
			SELECT
					KEEPER_ID
					,KEEPER_NAME
					,ANIMAL_ID
					,ANIMAL_NAME
			FROM
					KEEPER
			JOIN
					ANIMAL USING(KEEPER_ID)
		
		</select>
		
		
		<select id ="selectKeeperBuCondition"
				 resultType="keeper">
		<!-- 인자값 두개 이상일때는 파라미터를 사용을 적지 않는다/ 파라미터 생략 -->
		
		SELECT
				KEEPER_ID
				,KEEPER_NAME
		FROM
				KEEPER
						
		WHERE
		<choose>
			<when test="menuNo == 1">
				KEEPER_ID LIKE '%' || #{keyword} || '%'
			</when>	
			<when test="menuNo == 2">
				KEEPER_NAME LIKE '%' || #{keyword} || '%'
			</when>
			<when test="menuNo == 3">
				ZONE_ID LIKE '%' || #{keyword} || '%'
				</when>	
				<otherwise>
				KEEPER_ID = 1 OR 1 = 1
				</otherwise>
		  </choose>
		OTHER
		  BY
		  		KEEPER_ID
		  		
		
		</select>
		
		





















	</mapper>




